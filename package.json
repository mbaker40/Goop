{
  "name": "goop-tower",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A deliberately stupid 3D incremental game where you stack a wobbling tower of sentient goop.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "tsx sim-harness/report.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "break_infinity.js": "^2.0.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
